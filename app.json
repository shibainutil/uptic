{
  "expo": {
    "name": "Uptic",
    "slug": "uptic",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "dark",
    "scheme": "uptic",
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.uptic.app"
    },
    "android": {
      "package": "com.uptic.app",
      "googleServicesFile": "./google-services.json",
      "adaptiveIcon": {
        "backgroundColor": "#FFFFFF",
        "foregroundImage": "./assets/android-icon-foreground.png"
      },
      "predictiveBackGestureEnabled": false
    },
    "web": {
      "favicon": "./assets/favicon.png",
      "bundler": "metro"
    },
    "plugins": [
      "@react-native-firebase/app",
      "expo-router",
      "expo-status-bar",
      "expo-font",
      "expo-splash-screen",
      "expo-updates",
      "expo-notifications",
      "@react-native-google-signin/google-signin",
      [
        "expo-image-picker",
        {
          "photosPermission": "Uptic needs access to your photos to add images to exercises."
        }
      ]
    ],
    "updates": {
      "url": "https://u.expo.dev/bedf55f1-d06f-47e3-9156-77e99ab6b710",
      "enabled": true,
      "checkAutomatically": "ON_LOAD"
    },
    "runtimeVersion": {
      "policy": "appVersion"
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "bedf55f1-d06f-47e3-9156-77e99ab6b710"
      },
      "googleWebClientId": "752330312289-3habolld4fn9olio688d6l7afbafmfeh.apps.googleusercontent.com"
    },
    "owner": "anton.immel"
  }
}
